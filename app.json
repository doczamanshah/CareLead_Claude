{
  "expo": {
    "name": "CareLead",
    "slug": "carelead",
    "scheme": "carelead",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0C3B2E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.carelead.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0C3B2E"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.carelead.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ]
  }
}
